# --- Sourcing Google Places (OBLIGATOIRE) ---
# Console Google Cloud > APIs & Services > Places API (legacy) activée
GOOGLE_PLACES_API_KEY=

# --- Enrichissement site web (étape 5, optionnel) ---
# Fournisseur privilégié : Brave Search (gratuit 2000 req/mois, clé sur brave.com/search/api)
BRAVE_SEARCH_API_KEY=
# Fallback : Google Custom Search (nécessite un compte Google Cloud upgradé, bloquée en trial)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# --- Cascade légale niveau 2 (optionnel) ---
# Token API du compte data.inpi.fr (Registre National des Entreprises)
INPI_API_TOKEN=

# --- Cascade légale niveau 3 (optionnel, vérification ponctuelle) ---
# Clé du portail api.insee.fr (API Sirene 3.11)
INSEE_SIRENE_API_KEY=

# --- Extraction dirigeant depuis les avis (étape 4, optionnel) ---
ANTHROPIC_API_KEY=
